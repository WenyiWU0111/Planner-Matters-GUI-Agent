# =============================================================================
# Environment variables for GUI-Agent-Learn-From-Error (copy to .env and fill)
# =============================================================================
# Do not commit .env — it may contain secrets. This file documents required vars.
#
# Load into current shell (use one of these; do NOT use "export $(cat .env | xargs)"):
#   source planner-matter-inference/scripts/load_env.sh
#   source scripts/load_env.sh   (when already inside planner-matter-inference)
# Or one-liner from planner-matter-inference dir:
#   set -a; source <(grep -v '^#' .env | sed 's/[[:space:]]*#.*//' | grep -E '^[A-Za-z_][A-Za-z0-9_]*='); set +a

# -----------------------------------------------------------------------------
# API keys (required for respective features)
# -----------------------------------------------------------------------------
OPEN_ROUTER_API_KEY= # (required, used for language model API calls)
SERPAPI_API_KEY= # (optional, used for task generation)

# -----------------------------------------------------------------------------
# Paths (optional; scripts use relative defaults if unset)
# -----------------------------------------------------------------------------
INFERENCE_PROJECT_ROOT=./
MIND2WEB_DATA_ROOT=data/benchmarks/mind2web_executable
WEBVOYAGER_DATA_ROOT=data/benchmarks/webvoyager
MMINA_DATA_ROOT=data/benchmarks/mmina
FAISS_INDEX_PATH=memory_index/simple_text
DISCRETE_SUMMARY_PATH=memory/discrete_summary.json
CHECKPOINT_PATH=WenyiWU0111/Qwen2_5_7B_RL_planner
MEMORY_DATA_DIR=data/trajectories
